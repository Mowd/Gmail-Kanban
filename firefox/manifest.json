{
  "manifest_version": 3,
  "name": "Gmail Kanban",
  "version": "0.1.0",
  "description": "Turns Gmail inbox mail into a label-backed Kanban view.",
  "permissions": [
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://accounts.google.com/*",
    "https://gmail.googleapis.com/*",
    "https://mail.google.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "gmail-kanban@example.com",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": [
      "src/oauth-config.js",
      "src/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content/gmail-kanban.js"
      ],
      "css": [
        "content/gmail-kanban.css"
      ]
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Gmail Kanban",
    "default_popup": "popup/popup.html"
  }
}
